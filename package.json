{
  "name": "ffc-pr-calculator",
  "version": "1.16.40",
  "description": "FFC Progressive Reductions calculator",
  "homepage": "https://github.com/DEFRA/ffc-pr-calculator",
  "main": "app/index.js",
  "scripts": {
    "build": "webpack",
    "build:watch": "webpack --watch",
    "pretest": "npm run test:lint",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --coverage=false --onlyChanged --watch --runInBand",
    "test:lint": "eslint",
    "test:lint:fix": "eslint --fix",
    "test:debug": "node --inspect-brk=0.0.0.0 ./node_modules/jest/bin/jest.js --coverage=false --onlyChanged --watch --runInBand --no-cache",
    "start:watch": "npm-run-all --parallel build:watch start:nodemon",
    "start:debug": "nodemon --inspect-brk=0.0.0.0 --ext css,js,njk --legacy-watch app/index.js",
    "start:nodemon": "nodemon --inspect=0.0.0.0 --ext css,js,njk --legacy-watch app/index.js",
    "prepare": "node --eval \"const fs=require('fs'),cp=require('child_process');if(fs.existsSync('.git')&&!process.env.CI&&!process.env.TF_BUILD)cp.execSync('husky',{stdio:'inherit'})\""
  },
  "author": "Defra DDTS",
  "contributors": [
    "John Watson john.watson2@rpa.gov.uk",
    "Fay Toward fay.toward@rpa.gov.uk",
    "Steve Dickinson steve.dickinson@defra.gov.uk",
    "Fareed Mohammed fareed.mohammed@defra.gov.uk",
    "Kaz Iyiola kaz.iyiola@defra.gov.uk",
    "Simon Dunn simon.dunn1@defra.gov.uk",
    "Marc Templeton m.templeton@kainos.com",
    "Leigh Godson leigh.godson@atos.net",
    "Sam Plackett samuel.plackett@atos.net",
    "Oliver Lewington oliver.lewington@atos.net"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@hapi/boom": "9.1.1",
    "@hapi/crumb": "8.0.1",
    "@hapi/hapi": "20.2.2",
    "@hapi/inert": "6.0.3",
    "@hapi/vision": "6.0.1",
    "applicationinsights": "2.9.8",
    "govuk-frontend": "5.10.0",
    "hapi-pino": "13.0.0",
    "joi": "17.4.0",
    "moment": "2.29.4",
    "nunjucks": "3.2.4"
  },
  "devDependencies": {
    "blipp": "4.0.2",
    "clean-webpack-plugin": "3.0.0",
    "css-loader": "5.2.6",
    "eslint": "9.39.1",
    "html-webpack-plugin": "5.3.1",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-junit": "13.0.0",
    "mini-css-extract-plugin": "1.6.0",
    "neostandard": "0.12.2",
    "nodemon": "3.0.1",
    "npm-run-all": "4.1.5",
    "pino-pretty": "13.1.2",
    "resolve-url-loader": "5.0.0",
    "sass": "1.32.13",
    "sass-loader": "11.1.1",
    "style-loader": "2.0.0",
    "webpack": "5.105.4",
    "webpack-cli": "4.7.0"
  },
  "nodemonConfig": {
    "ignore": [
      "**/test-output/**"
    ]
  }
}
